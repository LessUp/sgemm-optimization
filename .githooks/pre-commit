#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

staged_files="$(git diff --cached --name-only --diff-filter=ACMR)"
[ -z "$staged_files" ] && exit 0

governance_glob='^(openspec/|AGENTS\.md$|CLAUDE\.md$|specs\.md$|README(\.zh-CN)?\.md$|CHANGELOG\.md$|CONTRIBUTING\.md$|index\.md$|docs/|\.github/copilot-instructions\.md$|\.github/workflows/)'
doc_glob='^(AGENTS\.md$|CLAUDE\.md$|specs\.md$|README(\.zh-CN)?\.md$|CHANGELOG\.md$|CONTRIBUTING\.md$|index\.md$|docs/|openspec/README\.md$|openspec/AGENTS\.md$)'
legacy_pattern='(^|[[:space:]`(])specs/(product|rfc|testing)/'

if printf '%s\n' "$staged_files" | grep -Eq "$governance_glob"; then
  echo "[pre-commit] Running OpenSpec validation..."
  openspec validate --all >/dev/null
fi

legacy_refs=0
while IFS= read -r file; do
  [[ -z "$file" ]] && continue
  if [[ "$file" =~ $doc_glob ]] && [[ -f "$file" ]]; then
    if grep -nE "$legacy_pattern" "$file" >/dev/null; then
      echo "[pre-commit] Legacy spec path found in $file"
      legacy_refs=1
    fi
  fi
done <<< "$staged_files"

if [[ "$legacy_refs" -ne 0 ]]; then
  echo "[pre-commit] Replace legacy spec paths with openspec/specs/* references."
  exit 1
fi
